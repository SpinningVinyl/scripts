#!/usr/bin/env bash

if [ $# -eq 0 ]; then
	echo "USAGE: activate PROGRAM_NAME"
fi

window_id=$(kwst find "$1" | head -n 1)
if [ "$window_id" = "" ]; then
	$1
else
	kwst activate-window "$window_id"
fi
qdbus6 org.kde.kglobalaccel /component/kwin org.kde.kglobalaccel.Component.invokeShortcut MoveMouseToFocus

